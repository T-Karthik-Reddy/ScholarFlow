# Optional: server-wide fallback Gemini API key. Users can instead enter their
# own key in the app (Settings), which is sent per-request and never stored
# on the server. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: force a specific Gemini model (otherwise the app tries a list of
# known models and uses the first one available for the key).
GEMINI_MODEL=
